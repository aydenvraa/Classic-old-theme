/* some status stuff stolen from https://refact0r.github.io/system24/src/unrounding.css */

@container style(--rounded-avatars: false) {
    /* hide round masks */
    [class^='listItem_'] [class^='wrapper_'] > [class^='svg_'] > mask,
    [class^='bannerSVGWrapper_'] > mask > circle {
        display: none;
    }

    [class^='mask_'] > foreignObject,
    [class^='svg_'] > foreignObject {
        mask-image: none;
    }

    /* fill circle mask on profile avatar */
    .overlay__75742:after,
    .overlay_c0bea0:after {
        border-radius: 0;
    }
}

@container style(--rounded-avatars: true) {
    /* Status indicator rounding */
    .wrapper__44b0c:has(rect)::after {
        border-radius: 50%;
    }

    /* Remove status indicator mask */
    .wrapper__44b0c .mask__44b0c foreignObject {
        mask-image: none;
        border-radius: 50% !important;
    }

    /* Voice avatar */
    .userAvatar__55bab {
        border-radius: 50% !important;
    }

}

/* hide status indicators */
[class^='mask_'] rect,
[class^='mask_'] circle,
[class^='mask_'] svg {
	display: none;
}

/* re-add status indicators */
.wrapper__44b0c:has(rect)::after {
	content: '';
	display: block;
	position: absolute;
	height: 100%;
	width: 100%;
}

g:has(rect[mask='url(#svg-mask-status-online)']),
g:has(rect[mask='url(#svg-mask-status-dnd)']),
g:has(rect[mask='url(#svg-mask-status-idle)']),
g:has(rect[mask='url(#svg-mask-status-offline)']),
g:has(rect[mask='url(#svg-mask-status-streaming)']) {
    display: none;
}

/* Online + Online Mobile */
.wrapper__44b0c:has(rect[mask='url(#svg-mask-status-online)'])::after,
.wrapper__44b0c:has(rect[mask='url(#svg-mask-status-online-mobile)'])::after {
	background: transparent !important;
    outline: 2px solid #57CBDE;
}

/* Do not disturb */
.wrapper__44b0c:has(rect[mask='url(#svg-mask-status-dnd)'])::after {
    background: transparent !important;
    outline: 2px solid #ff4133;
}

/* Idle */
.wrapper__44b0c:has(rect[mask='url(#svg-mask-status-idle)'])::after {
    background: transparent !important;
    outline: 2px solid #f58b05;
}

/* Offline */
.wrapper__44b0c:has(rect[mask='url(#svg-mask-status-offline)'])::after {
    background: transparent !important;
    outline: 2px solid #898989;
}

/* Streaming */
.wrapper__44b0c:has(rect[mask='url(#svg-mask-status-streaming)'])::after {
    background: transparent !important;
    outline: 2px solid #9147ff;
}

