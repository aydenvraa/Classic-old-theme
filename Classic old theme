================================================== */


/* profile modal shell */

[class*="userProfileModal"],
[class*="profileModal"],
.root__24502 {

    background:var(--fc-bg-side)!important;
    border:1px solid var(--fc-border)!important;
    border-radius:3px!important;
}


/* remove modern floating card style */

[class*="userProfileModal"] *,
[class*="profileModal"] * {

    border-radius:2px!important;
}


/* profile banner */

[class*="banner"] {

    filter:
        saturate(.75)
        brightness(.85)!important;

    border-bottom:
        1px solid var(--fc-border)!important;
}


/* dark overlay old discord style */

[class*="banner"]::after {

    background:
        linear-gradient(
            rgba(0,0,0,.25),
            transparent
        )!important;
}


/* avatar frame */

[class*="avatarWrapper"],
[class*="avatar"] {

    border-radius:2px!important;
}


[class*="avatar"] img {

    border-radius:2px!important;
}


/* avatar border */

[class*="avatar"] {

    border:
        3px solid var(--fc-bg-side)!important;
}


/* username */

[class*="nickname"],
[class*="displayName"] {

    color:var(--fc-text)!important;

    font-size:20px!important;

    font-weight:700!important;
}


/* discriminator / username */

[class*="username"] {

    color:
        var(--fc-muted)!important;
}


/* status text */

[class*="customStatus"] {

    color:
        var(--fc-muted)!important;
}


/* profile body */

[class*="body"],
[class*="bodyInnerWrapper"] {

    background:
        var(--fc-bg-main)!important;
}


/* profile cards */

[class*="section"] {

    background:
        var(--fc-panel)!important;

    border:
        1px solid var(--fc-border)!important;

    margin-bottom:8px!important;

    padding:12px!important;
}


/* about me */

[class*="bio"],
[class*="userBio"] {

    color:
        var(--fc-text)!important;

    line-height:1.45!important;
}


/* connections */

[class*="connectedAccount"] {

    background:
        var(--fc-bg-side)!important;

    border:
        1px solid var(--fc-border)!important;
}


[class*="connectedAccount"]:hover {

    background:
        var(--fc-hover)!important;
}


/* profile badges */

[class*="badge"] {

    border-radius:2px!important;

    filter:saturate(.8);
}


/* roles */

[class*="role"] {

    background:
        #505646!important;

    border:
        1px solid var(--fc-border)!important;

    color:
        var(--fc-text)!important;

    padding:
        3px 7px!important;
}


/* remove role circles */

[class*="roleCircle"] {

    display:none!important;
}


/* profile buttons */

[class*="profileAction"],
[class*="actionButton"] {

    background:
        var(--fc-panel)!important;

    border:
        1px solid var(--fc-border)!important;

    color:
        var(--fc-muted)!important;
}


[class*="profileAction"]:hover,
[class*="actionButton"]:hover {

    background:
        var(--fc-accent)!important;

    color:white!important;
}


/* tabs */

[class*="tabBar"] {

    background:
        var(--fc-panel)!important;

    border-bottom:
        1px solid var(--fc-border)!important;
}


[class*="tabBarItem"] {

    border-radius:0!important;

    color:
        var(--fc-muted)!important;
}


[class*="tabBarItem"]:hover {

    background:
        var(--fc-hover)!important;
}


[class*="tabBarItem"][aria-selected="true"] {

    background:
        var(--fc-accent)!important;

    color:white!important;
}



