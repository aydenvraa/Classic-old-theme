    border-left-color:var(--fc-border)!important;
}


/* newer message wrappers */

[class*="message"] {
    --background-message-hover:rgba(255,255,255,.025);
}


[class*="message"]:hover {
    background:rgba(255,255,255,.025)!important;
}


/* newer channel items */

[class*="channel"][aria-selected="true"] {
    background:var(--fc-accent)!important;
}


/* newer popouts */

[class*="popout"] {
    background:var(--fc-bg-dark)!important;
    border:1px solid var(--fc-border)!important;
}


/* newer menus */

[class*="menu"] {
    background:var(--fc-bg-dark)!important;
    border:1px solid var(--fc-border)!important;
}


[class*="menuItem"]:hover {
    background:var(--fc-active)!important;
}


/* newer buttons */

[class*="button"] {
    border-radius:2px!important;
}


/* newer avatars */

[class*="avatar"] img {
    border-radius:2px!important;
}


/* newer role pills */

[class*="role"] {
    border-radius:2px!important;
}


/* newer modals */

[class*="modal"] {
    background:var(--fc-panel)!important;
    border:1px solid var(--fc-border)!important;
}


/* newer text */

[class*="username"] {
    color:var(--fc-text)!important;
}


[class*="timestamp"] {
    color:var(--fc-faint)!important;
}


/* old discord compact feeling */

[class*="message"] [class*="contents"] {
    margin-left:0;
}


[class*="chatContent"] {
    background:var(--fc-bg-main)!important;
}


/* final compatibility */

[class*="wrapper"] {
    box-shadow:none!important;
}


[class*="container"] {
    box-shadow:none!important;
}
